#--------------------------------------------------------------------
# CodeIgniter 4 環境設定
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# App
#--------------------------------------------------------------------
app.baseURL = 'http://localhost/'
app.forceGlobalSecureRequests = false

#--------------------------------------------------------------------
# Database
#--------------------------------------------------------------------
database.default.hostname = mysql
database.default.database = inventory_db
database.default.username = app
database.default.password = secret
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port     = 3306

#--------------------------------------------------------------------
# Cache (Redis)
#--------------------------------------------------------------------
cache.handler = redis
cache.redis.host     = redis
cache.redis.password = null
cache.redis.port     = 6379
cache.redis.timeout  = 0
cache.redis.database = 0

#--------------------------------------------------------------------
# JWT
#--------------------------------------------------------------------
jwt.secret      = change-me-to-a-256-bit-random-secret
jwt.ttl         = 3600
jwt.refresh_ttl = 604800

#--------------------------------------------------------------------
# Storage (MinIO / S3)
#--------------------------------------------------------------------
storage.driver = local

#--------------------------------------------------------------------
# Session
#--------------------------------------------------------------------
session.driver    = CodeIgniter\Session\Handlers\RedisSessionHandler
session.savePath  = tcp://redis:6379
